generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model PedidoLog {
  id           String   @id @default(cuid())
  codigo       String?  @db.Text
  payload      Json
  operacao     String   @db.Text
  status       String   @db.Text
  dataOperacao DateTime @map("data_operacao")

  @@map("pedidos_log")
}

model EntidadeLog {
  id           String   @id @default(cuid())
  codigo       String?  @db.Text
  payload      Json
  operacao     String   @db.Text
  status       String   @db.Text
  dataOperacao DateTime @map("data_operacao")

  @@map("entidades_log")
}

model ProdutoLog {
  id           String   @id @default(cuid())
  codigo       String?  @db.Text
  payload      Json
  operacao     String   @db.Text
  status       String   @db.Text
  dataOperacao DateTime @map("data_operacao")

  @@map("produtos_log")
}

model OrdemServicoLog {
  id           String   @id @default(cuid())
  codigo       String?  @db.Text
  payload      Json
  operacao     String   @db.Text
  status       String   @db.Text
  dataOperacao DateTime @map("data_operacao")

  @@map("ordens_servico_log")
}

model HealthLog {
  id           String   @id @default(cuid())
  codigo       String?  @db.Text
  payload      Json
  operacao     String   @db.Text
  status       String   @db.Text
  dataOperacao DateTime @map("data_operacao")

  @@map("health_log")
}

model ApiLog {
  id           String   @id @default(cuid())
  recurso      String   @db.Text
  rota         String?  @db.Text
  metodo       String?  @db.Text
  codigo       String?  @db.Text
  payload      Json
  operacao     String   @db.Text
  status       String   @db.Text
  dataOperacao DateTime @map("data_operacao")

  @@map("api_logs")
}
