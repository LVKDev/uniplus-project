# ========================================
# SERVIDOR
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# DATABASE (PostgreSQL / Supabase)
# ========================================
# Exemplo Supabase:
# postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/mydb

# ========================================
# AUTENTICAÇÃO JWT
# ========================================
# JWT Secret: chave para assinar tokens JWT
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_32_chars_minimum_here_1234567
JWT_EXPIRE=7d

# ========================================
# ENCRIPTAÇÃO (Credenciais Uniplus)
# ========================================
# Chave para encriptar credenciais por unidade
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ========================================
# SUPER ADMIN (Seed Automático)
# ========================================
# Criado automaticamente via: npm run db:seed
# Para mudar: edite abaixo e execute npm run db:seed
SUPERADMIN_EMAIL=admin@uniplus.local
SUPERADMIN_PASSWORD=SuperAdmin@2026

# ========================================
# ⚠️ IMPORTANTE
# ========================================
# ❌ NÃO coloque credenciais de clientes Uniplus aqui!
# ✅ Credenciais são armazenadas por UNIDADE no banco de dados (encriptadas)
# ✅ SUPER_ADMIN cria/gerencia credenciais via: POST /api/unidades/full-credentials
# ✅ Cada unidade tem credenciais DIFERENTES e encriptadas com AES-256-GCM
