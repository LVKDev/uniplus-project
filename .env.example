# ========================================
# SERVIDOR
# ========================================
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ========================================
# AUTENTICACAO DA API
# ========================================
API_USER=usuario_api
API_PASS=senha_api_forte

# ========================================
# POSTGRESQL
# ========================================
# Externo (exemplo):
# DATABASE_URL=postgresql://usuario:senha@SEU_HOST_DB:5432/uniplus
#
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uniplus
#
# Interno Docker:
DATABASE_INTERNAL_URL=postgresql://postgres:postgres@postgres:5432/uniplus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=uniplus

# ========================================
# REDIS
# ========================================
# Externo (exemplo):
# REDIS_URL=redis://:senha@SEU_HOST_REDIS:6379/0
#
# Local:
REDIS_URL=redis://localhost:6379/0
#
# Interno Docker:
REDIS_INTERNAL_URL=redis://:changeme@redis:6379/0
REDIS_PASSWORD=changeme

# ========================================
# UNIPLUS
# ========================================
UNIPLUS_ACCOUNT=seu_tenant_uniplus
UNIPLUS_SERVER_URL=https://exemplo.webuniplus.com
UNIPLUS_BASE_URL=https://exemplo.webuniplus.com/public-api
UNIPLUS_AUTH_BASIC=base64_client_id_client_secret
UNIPLUS_TOKEN=
UNIPLUS_ALL_LIMIT=100

# ========================================
# PORTAL COMERCIAL
# ========================================
PORTAL_BASE_URL=https://portal.exemplo.com
PORTAL_API_TOKEN=token_do_portal

# ========================================
# OBSERVACOES
# ========================================
# Nao commite credenciais reais. O arquivo .env permanece ignorado pelo Git.
# Use DATABASE_URL/REDIS_URL para validar acesso externo ou local.
# Use DATABASE_INTERNAL_URL/REDIS_INTERNAL_URL para validar rede interna Docker.
