{
  "name": "uniplus-project",
  "version": "1.0.0",
  "description": "Backend Node.js para integrar UniPlus e Supabase",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest __tests__/security.test.js",
    "test:ratelimit": "jest __tests__/ratelimit-cors.test.js",
    "infra:check": "node scripts/check-infra.js",
    "validate:ref8": "node scripts/validate-ref8.js",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "rate-limit-redis": "^4.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.18.0",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
